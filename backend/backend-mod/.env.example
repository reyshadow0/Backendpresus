# =====================================================
# Variables de entorno requeridas — Pre-Sustentaciones
# Copia este archivo a .env y ajusta los valores
# NUNCA subas .env a control de versiones
# =====================================================

# Base de Datos PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/presusDb
DB_USERNAME=tu_usuario_postgres
DB_PASSWORD=tu_password_seguro

# JWT — Genera un nuevo secret en producción con:
# openssl rand -hex 32
JWT_SECRET=reemplazar_con_clave_aleatoria_de_64_chars_minimo
JWT_EXPIRATION=86400000
