server.port=8080
spring.jpa.database=postgresql
spring.jpa.show-sql=true
spring.jpa.hibernate.ddl-auto=update
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect
spring.datasource.driver-class-name=org.postgresql.Driver
spring.datasource.url=${DB_URL:jdbc:postgresql://localhost:5432/presusDb}
spring.datasource.username=${DB_USERNAME:TU_USUARIO_DB}
spring.datasource.password=${DB_PASSWORD:TU_PASSWORD_DB}

# File Upload
spring.servlet.multipart.enabled=true
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB
app.upload.dir=${UPLOAD_DIR:uploads/anteproyectos}
app.upload.dir.tutorias=${UPLOAD_DIR_TUTORIAS:uploads/tutorias}

# JWT Configuration
jwt.secret=${JWT_SECRET:TU_JWT_SECRET_BASE64}
jwt.expiration=${JWT_EXPIRATION:86400000}

# Email (Gmail SMTP)
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=${MAIL_USERNAME:TU_CORREO@gmail.com}
spring.mail.password=${MAIL_PASSWORD:TU_APP_PASSWORD_GMAIL}
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.starttls.required=true
app.mail.from=${MAIL_USERNAME:TU_CORREO@gmail.com}
app.mail.enabled=${MAIL_ENABLED:true}
